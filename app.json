{
  "expo": {
    "name": "ConnectHQ",
    "slug": "EventPass",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/connecthq-square.png",
    "scheme": "connecthq",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "googleServicesFile": "./GoogleService-Info.plist",
      "bundleIdentifier": "Event.Pass",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": ["fetch", "remote-notification"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0f172a",
        "foregroundImage": "./assets/images/connecthq-square.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "Event.Pass",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/connecthq.png",
          "imageWidth": 400,
          "resizeMode": "contain",
          "backgroundColor": "#0f172a",
          "dark": {
            "image": "./assets/images/connecthq.png",
            "imageWidth": 400,
            "resizeMode": "contain",
            "backgroundColor": "#0f172a"
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow ConnectHQ to use the camera to scan attendee QR codes."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow ConnectHQ to access your photos to save certificates.",
          "savePhotosPermission": "Allow ConnectHQ to save certificates to your photos."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/connecthq-square.png",
          "color": "#4f46e5",
          "defaultChannel": "checkins",
          "mode": "production"
        }
      ],
      "expo-task-manager"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9ae61a72-a51d-4ab6-b032-a67f1fa70e80"
      }
    },
    "owner": "techwolf78"
  }
}
