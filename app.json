{
  "expo": {
    "name": "ConnectHQ",
    "slug": "EventPass",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/connecthq-square.png",
    "scheme": "connecthq",
    "userInterfaceStyle": "automatic",

    "ios": {
      "supportsTablet": true,
      "googleServicesFile": "./GoogleService-Info.plist",
      "bundleIdentifier": "com.connecthq.app",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": ["fetch", "remote-notification"]
      }
    },

    "android": {
      "package": "com.connecthq.app",
      "googleServicesFile": "./google-services.json",
      "predictiveBackGestureEnabled": false,

      "adaptiveIcon": {
        "backgroundColor": "#0f172a",
        "foregroundImage": "./assets/images/connecthq-square.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },

      "permissions": [
        "android.permission.CAMERA",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE"
      ]
    },

    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },

    "plugins": [
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static",
            "deploymentTarget": "15.1",
            "forceStaticLinking": ["RNFBApp", "RNFBFirestore", "RNFBAuth"]
          }
        }
      ],
      "@react-native-firebase/app",
      "expo-router",

      [
        "expo-splash-screen",
        {
          "image": "./assets/images/connecthq.png",
          "imageWidth": 400,
          "resizeMode": "contain",
          "backgroundColor": "#0f172a",

          "dark": {
            "image": "./assets/images/connecthq.png",
            "imageWidth": 400,
            "resizeMode": "contain",
            "backgroundColor": "#0f172a"
          }
        }
      ],

      [
        "expo-camera",
        {
          "cameraPermission": "ConnectHQ requires camera access to scan event QR codes for attendee check-in and attendance tracking."
        }
      ],

      [
        "expo-media-library",
        {
          "photosPermission": "Allow ConnectHQ to access photos to save certificates.",
          "savePhotosPermission": "Allow ConnectHQ to save certificates."
        }
      ],

      [
        "expo-notifications",
        {
          "icon": "./assets/images/connecthq-square.png",
          "color": "#4f46e5",
          "defaultChannel": "checkins",
          "mode": "production"
        }
      ],

      "expo-task-manager"
    ],

    "experiments": {
      "typedRoutes": true
    },

    "extra": {
      "router": {},
      "eas": {
        "projectId": "9ae61a72-a51d-4ab6-b032-a67f1fa70e80"
      }
    },

    "owner": "techwolf78"
  }
}
